# SmartHire frontend environment

# Backend API base URL
# Local dev usually works best through Vite proxy:
VITE_API_BASE_URL=/api

# Assessment API base URL
VITE_ASSESSMENT_API=/assessment-api

# Optional Vite dev proxy targets (defaults: http://127.0.0.1:8000)
# Useful if backend runs on another host/port.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_ASSESSMENT_PROXY_TARGET=http://127.0.0.1:8000

# Proctoring capture intervals (milliseconds)
# Default behavior if omitted:
# - Camera frame analysis: 5000
# - Audio analysis: 4000
# - Camera snapshot capture: 8000
VITE_PROCTOR_CAMERA_ANALYSIS_INTERVAL_MS=5000
VITE_PROCTOR_AUDIO_ANALYSIS_INTERVAL_MS=4000
VITE_PROCTOR_CAMERA_SNAPSHOT_INTERVAL_MS=8000
