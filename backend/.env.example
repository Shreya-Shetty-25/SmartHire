# SmartHire backend environment

# Database (Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production

# LLM provider selection (set exactly one to true)
USE_AZURE_OPENAI=false
USE_GEMINI=false
USE_GROQ=false

# Twilio webhook base (optional)
PUBLIC_BASE_URL=

# Exam portal base URL (candidate-facing) - typically your frontend ngrok URL
EXAM_PORTAL_BASE_URL=

# CORS origins (comma-separated). Add your ngrok origins here.
# Example: http://localhost:5173,https://abcd-12-34-56-78.ngrok-free.app
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174

# SMTP for exam invite emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Smart Hire
SMTP_USE_STARTTLS=true
