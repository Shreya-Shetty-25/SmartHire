# SmartHire backend environment

# Database (Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/postgres
JOBS_DATABASE_URL=

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-key-in-production
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_NAME=Admin
BOOTSTRAP_ADMIN_EMAIL=admin@mastek.com
BOOTSTRAP_ADMIN_PASSWORD=admin@123

# LLM provider selection (set exactly one to true)
USE_OPENAI=false
USE_AZURE_OPENAI=false
USE_GEMINI=false
USE_GROQ=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio webhook base (optional)
PUBLIC_BASE_URL=

# ElevenLabs (voice + transcription)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STT_MODEL_ID=scribe_v2

# Exam portal base URL (candidate-facing) - typically your frontend ngrok URL
EXAM_PORTAL_BASE_URL=

# Assessment storage and callback settings
ASSESSMENT_DATABASE_URL=sqlite:///./assessment_data.db
MAIN_BACKEND_BASE_URL=http://127.0.0.1:8000
PUBLIC_CALL_BASE_URL=
EMAIL_MODE=auto

# Optional assessment question-generation fallback
ASSESSMENT_QUESTION_GENERATION_MODE=fast
USE_HF_LLM=false
HF_API_TOKEN=
HF_MODEL=google/flan-t5-base

# CORS origins (comma-separated). Add your ngrok origins here.
# Example: http://localhost:5173,https://abcd-12-34-56-78.ngrok-free.app
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174

# SMTP for exam invite emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Smart Hire
SMTP_USE_STARTTLS=true
